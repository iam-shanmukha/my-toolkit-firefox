{
    "manifest_version": 3,
    "name": "AI Tab Toolkit",
    "version": "1.0",
    "description": "Unlocks useful features",
    "browser_specific_settings": {
        "gecko": {
            "id": "toolkit@iam-shanmukha",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "AI Tab Toolkit"
    },
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "youtube-shorts-blocker.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "youtube-player-buttons.js",
                "youtube-watch-t-keypress.js",
                "youtube-playlist-buttons.js",
                "yt-music-playlist-filtering.js",
                "youtube-topbar-buttons.js",
                "youtube-homepage-watch-later.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "domain-blocker.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://x.com/*",
                "*://www.x.com/*"
            ],
            "js": [
                "text-selection-popup.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://claude.ai/*",
                "*://claude.com/*"
            ],
            "js": [
                "claude-input.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://gemini.google.com/*"
            ],
            "js": [
                "gemini-input.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://chatgpt.com/*",
                "*://chat.openai.com/*"
            ],
            "js": [
                "chatgpt-input.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "*://www.youtube.com/*",
        "*://claude.ai/*",
        "*://claude.com/*",
        "*://gemini.google.com/*",
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "<all_urls>"
    ],
    "permissions": [
        "storage",
        "tabs",
        "contextMenus",
        "bookmarks"
    ],
    "background": {
        "scripts": ["custom-context-menu-actions.js"]
    },
    "commands": {
        "close-other-tabs-shortcut": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y",
                "mac": "Command+Shift+Y"
            },
            "description": "Close all tabs except the current tab and pinned tabs"
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}
